# ═══════════════════════════════════════════════════════════════════
# .env.example — SICOP-MDSJ
# Copiar a .env y ajustar los valores. NO commitear .env al repo.
# ═══════════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-32-byte-string
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_HOURS=8

# ─── PostgreSQL (base intermedia) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sicop
POSTGRES_USER=sicop
POSTGRES_PASSWORD=sicop_dev_pw

# ─── Redis (cache) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── SIGA (SQL Server) ──────────────────────────────────────────────
# Dos modos de auth:
#   MSSQL_AUTH=windows → usa las credenciales del usuario Windows actual (dev local)
#   MSSQL_AUTH=sql     → usa MSSQL_USER + MSSQL_PASSWORD (recomendado en prod)
MSSQL_AUTH=windows
MSSQL_SERVER=.
MSSQL_PORT=1433
MSSQL_DB=SIGA_300687
MSSQL_ODBC_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_TRUST_CERT=yes
MSSQL_ENCRYPT=no

# Solo si MSSQL_AUTH=sql
MSSQL_USER=
MSSQL_PASSWORD=

# ─── API MEF (Datos Abiertos) ───────────────────────────────────────
MEF_BASE_URL=https://api.datosabiertos.mef.gob.pe/DatosAbiertos/v1
MEF_RESOURCE_EJECUCION=615644aa-ef73-4358-b4e0-0c20931632f3
MEF_RESOURCE_INVERSIONES=f9cc4ba0-931a-4b70-86c9-eacbd8c68596

# ─── Entidad (fijos del proyecto) ───────────────────────────────────
SEC_EJEC=300687
UBIGEO=080104
ANO_VIGENTE=2026

# ─── Uploads ────────────────────────────────────────────────────────
UPLOAD_PATH=/var/data/uploads
UPLOAD_MAX_MB_FOTO=5
UPLOAD_MAX_MB_DOCUMENTO=20

# ─── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── reCAPTCHA v3 (observaciones ciudadanas) ────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ─── Jobs (sincronización) ──────────────────────────────────────────
# Cron format: hora del sistema donde corre el backend
SYNC_SIAF_HOUR=3
SYNC_SIAF_MINUTE=0
