# backend/.env.example
# Este archivo se copia desde el raíz. En dev, el backend lee su propio .env local
# apuntando a los servicios expuestos en el host (postgres:5432, redis:6379).

# ─── App ────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-32-byte-string
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_HOURS=8

# ─── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sicop
POSTGRES_USER=sicop
POSTGRES_PASSWORD=sicop_dev_pw

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── SQL Server SIGA ────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=SIGA_300687
MSSQL_USER=sa
MSSQL_SA_PASSWORD=Sicop_Dev_2026!
MSSQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_TRUST_CERT=yes
MSSQL_LECTOR_USER=lector_presupuesto
MSSQL_LECTOR_PASSWORD=change-me-lector-pw

# ─── API MEF ────────────────────────────────────────────────────────
MEF_BASE_URL=https://api.datosabiertos.mef.gob.pe/DatosAbiertos/v1
MEF_RESOURCE_EJECUCION=615644aa-ef73-4358-b4e0-0c20931632f3
MEF_RESOURCE_INVERSIONES=f9cc4ba0-931a-4b70-86c9-eacbd8c68596

# ─── Entidad ────────────────────────────────────────────────────────
SEC_EJEC=300687
UBIGEO=080104
ANO_VIGENTE=2026

# ─── Uploads ────────────────────────────────────────────────────────
UPLOAD_PATH=./var/uploads
UPLOAD_MAX_MB_FOTO=5
UPLOAD_MAX_MB_DOCUMENTO=20

# ─── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── reCAPTCHA ──────────────────────────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ─── Jobs ───────────────────────────────────────────────────────────
SYNC_SIAF_HOUR=3
SYNC_SIAF_MINUTE=0
